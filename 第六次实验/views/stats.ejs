<%- include('partials/header') %>

<div class="card" style="text-align:center; margin-top: 10px;">
  <h2 style="font-family: 'TitleFont','SimSun',serif; font-size: 2rem; color: var(--primary); margin-bottom: 6px;">📊 数据统计中心</h2>
  <p style="color: var(--text-muted);">全方位了解旅途笔记的平台动态</p>
</div>

<div class="stats-overview">
  <div class="stat-box">
    <div class="stat-num"><%= totalTravels %></div>
    <div class="stat-label">📝 游记总数</div>
  </div>
  <div class="stat-box">
    <div class="stat-num"><%= totalUsers %></div>
    <div class="stat-label">👥 注册用户</div>
  </div>
  <div class="stat-box">
    <div class="stat-num"><%= totalViews %></div>
    <div class="stat-label">👁 总浏览量</div>
  </div>
  <div class="stat-box">
    <div class="stat-num"><%= totalComments %></div>
    <div class="stat-label">💬 总评论数</div>
  </div>
</div>

<div class="charts-grid">
  <div class="card chart-card">
    <h3 class="chart-title">🏆 热门目的地排行</h3>
    <canvas id="destChart"></canvas>
  </div>
  <div class="card chart-card">
    <h3 class="chart-title">📂 游记分类占比</h3>
    <canvas id="catChart"></canvas>
  </div>
</div>

<div class="charts-grid">
  <div class="card chart-card" style="grid-column: 1 / -1;">
    <h3 class="chart-title">📈 月度发布趋势（近12个月）</h3>
    <canvas id="monthChart"></canvas>
  </div>
</div>

<div class="section-header">
  <div class="accent-line"></div>
  <h2 class="section-title">🔥 最高浏览游记 TOP8</h2>
</div>
<div class="travel-grid">
  <% topTravels.forEach(function(travel) { %>
    <div class="travel-card">
      <a href="/travel/<%= travel._id %>">
        <div class="img-wrapper">
          <img src="<%= travel.image || '/images/default.jpg' %>" alt="<%= travel.title %>">
          <span class="category-tag"><%= travel.category %></span>
        </div>
      </a>
      <div class="card-body">
        <h3><a href="/travel/<%= travel._id %>"><%= travel.title %></a></h3>
        <div class="card-meta">
          <span>📍 <%= travel.destination %></span>
          <span>👁 <%= travel.views %></span>
          <span>❤ <%= travel.likes.length %></span>
        </div>
      </div>
    </div>
  <% }); %>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
  Chart.defaults.color = '#485460';
  Chart.defaults.font.family = '-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif';

  var destData = <%- destStats %>;
  new Chart(document.getElementById('destChart'), {
    type: 'bar',
    data: {
      labels: destData.map(function(d) { return d._id; }),
      datasets: [{
        label: '游记数量',
        data: destData.map(function(d) { return d.count; }),
        backgroundColor: 'rgba(233, 69, 96, 0.7)',
        borderColor: 'rgba(233, 69, 96, 1)',
        borderWidth: 1,
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      indexAxis: 'y',
      plugins: { legend: { display: false } },
      scales: {
        x: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
        y: { grid: { display: false } }
      }
    }
  });

  var catData = <%- catStats %>;
  new Chart(document.getElementById('catChart'), {
    type: 'doughnut',
    data: {
      labels: catData.map(function(d) { return d._id; }),
      datasets: [{
        data: catData.map(function(d) { return d.count; }),
        backgroundColor: ['rgba(233,69,96,0.8)','rgba(12,45,90,0.8)','rgba(212,168,83,0.8)','rgba(26,61,110,0.8)','rgba(240,215,140,0.8)','rgba(128,142,155,0.8)','rgba(72,84,96,0.8)'],
        borderWidth: 2,
        borderColor: '#fff'
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true } }
      }
    }
  });

  var monthData = <%- monthStats %>;
  new Chart(document.getElementById('monthChart'), {
    type: 'line',
    data: {
      labels: monthData.map(function(d) { return d._id; }),
      datasets: [{
        label: '游记发布数',
        data: monthData.map(function(d) { return d.count; }),
        borderColor: 'rgba(233, 69, 96, 1)',
        backgroundColor: 'rgba(233, 69, 96, 0.1)',
        fill: true,
        tension: 0.4,
        pointRadius: 4,
        pointBackgroundColor: 'rgba(233, 69, 96, 1)'
      }, {
        label: '浏览量',
        data: monthData.map(function(d) { return d.views; }),
        borderColor: 'rgba(12, 45, 90, 1)',
        backgroundColor: 'rgba(12, 45, 90, 0.05)',
        fill: true,
        tension: 0.4,
        pointRadius: 4,
        pointBackgroundColor: 'rgba(12, 45, 90, 1)',
        yAxisID: 'y1'
      }]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { position: 'top' } },
      scales: {
        x: { grid: { color: 'rgba(0,0,0,0.05)' } },
        y: { beginAtZero: true, title: { display: true, text: '发布数' }, grid: { color: 'rgba(0,0,0,0.05)' } },
        y1: { beginAtZero: true, position: 'right', title: { display: true, text: '浏览量' }, grid: { display: false } }
      }
    }
  });
</script>

<%- include('partials/footer') %>
