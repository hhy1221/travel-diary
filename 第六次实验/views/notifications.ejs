<%- include('partials/header') %>

<h2 class="section-title">🔔 我的通知</h2>

<% if (notifications.length === 0) { %>
  <div class="card" style="text-align: center; padding: 40px;">
    <p>暂时没有新的通知</p>
  </div>
<% } else { %>
  <div style="text-align: right; margin-bottom: 20px;">
    <form action="/notifications/read-all" method="POST" style="display: inline;">
      <button type="submit" class="btn btn-secondary btn-sm">✔ 全部标为已读</button>
    </form>
  </div>

  <% notifications.forEach(function(notif) { %>
    <div class="card" style="display: flex; align-items: center; justify-content: space-between; opacity: <%= notif.read ? 0.5 : 1 %>;">
      <div style="flex: 1;">
        <% if (notif.type === 'like') { %>
          <p>
            <strong><%= notif.sender.username %></strong> 赞了你的游记
            <a href="/travel/<%= notif.travel._id %>">《<%= notif.travel.title %>》</a>
          </p>
        <% } else if (notif.type === 'comment') { %>
          <p>
            <strong><%= notif.sender.username %></strong> 评论了你的游记
            <a href="/travel/<%= notif.travel._id %>">《<%= notif.travel.title %>》</a>
          </p>
        <% } %>
        <p style="color: var(--light); font-size: 0.85rem;"><%= notif.createdAt.toLocaleDateString('zh-CN') %> <%= notif.createdAt.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' }) %></p>
      </div>
      <% if (!notif.read) { %>
        <span style="background: var(--accent); color: white; padding: 2px 10px; border-radius: 12px; font-size: 0.8rem;">未读</span>
      <% } %>
    </div>
  <% }); %>
<% } %>

<%- include('partials/footer') %>