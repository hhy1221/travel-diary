<%- include('partials/header') %>

<div class="card" style="max-width: 600px; margin: 0 auto;">
  <h2 style="text-align: center; margin-bottom: 25px; color: var(--primary);">个人设置</h2>

  <% if (typeof success !== 'undefined') { %>
    <div style="background: #d4edda; padding: 10px; border-radius: 8px; margin-bottom: 15px; color: #155724;">
      <%= success %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined') { %>
    <div style="background: #ffeaa7; padding: 10px; border-radius: 8px; margin-bottom: 15px; color: #d63031;">
      <%= error %>
    </div>
  <% } %>

  <form action="/settings" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label>当前头像</label>
      <img src="<%= user.avatar %>" alt="头像" style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%; margin-bottom: 10px;">
      <input type="file" name="avatar" accept="image/*">
    </div>

    <div class="form-group">
      <label for="bio">个人简介</label>
      <textarea name="bio" id="bio" rows="3" maxlength="200" placeholder="介绍一下自己..."><%= user.bio || '' %></textarea>
    </div>

    <button type="submit" class="btn btn-primary" style="width: 100%;">保存修改</button>
  </form>
</div>

<%- include('partials/footer') %>