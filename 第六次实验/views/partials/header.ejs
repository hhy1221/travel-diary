<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : '旅途笔记' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">旅途<span class="logo-dot">笔记</span></a>
      <%# 以下汉堡菜单按钮由"Trae AI (DeepSeek-V4-Pro)"生成 %>
      <button class="hamburger" id="hamburger-btn" aria-label="菜单">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <%# AI 生成结束 %>
      <ul class="nav-menu" id="nav-menu">
        <li><a href="/">首页</a></li>
        <li><a href="/features">功能</a></li>
        <% if (currentUser) { %>
          <li><a href="/create">写游记</a></li>
          <li>
  <a href="/notifications" style="position: relative;">
    🔔 通知
    <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
      <span style="position: absolute; top: -6px; right: -12px; background: var(--accent); color: white; font-size: 0.7rem; padding: 1px 6px; border-radius: 10px;">
        <%= unreadCount %>
      </span>
    <% } %>
  </a>
</li>
          <li><a href="/my">我的</a></li>
          <li><a href="/settings">设置</a></li>
          <% if (currentUser.isAdmin) { %>
            <li><a href="/admin" style="color: var(--gold-light);">⚙ 后台</a></li>
          <% } %>
          <li><a href="/logout">退出</a></li>
          <li class="nav-user"><%= currentUser.username %></li>
        <% } else { %>
          <li><a href="/login">登录</a></li>
          <li><a href="/register">注册</a></li>
        <% } %>
      </ul>
    </div>
  </nav>

  <% if (currentPath === '/' || currentPath.startsWith('/search')) { %>
  <div class="search-bar">
    <form action="/search" method="GET">
      <input type="text" name="q" placeholder="搜索目的地、游记标题..." value="<%= typeof query !== 'undefined' ? query : '' %>">
      <button type="submit">🔍 搜索</button>
    </form>
  </div>
  <% } %>

  <script>
    (function() {
      var btn = document.getElementById('hamburger-btn');
      var menu = document.getElementById('nav-menu');
      if (!btn || !menu) return;

      function isMobile() {
        return window.getComputedStyle(btn).display !== 'none';
      }

      if (isMobile()) {
        menu.style.display = 'none';
      }

      btn.addEventListener('click', function(e) {
        if (!isMobile()) return;
        e.stopPropagation();
        var isOpen = menu.style.display === 'flex';
        menu.style.display = isOpen ? 'none' : 'flex';
        if (isOpen) btn.classList.remove('active');
        else btn.classList.add('active');
      });

      document.addEventListener('click', function(e) {
        if (!isMobile()) return;
        if (menu.style.display === 'flex' && !menu.contains(e.target) && !btn.contains(e.target)) {
          menu.style.display = 'none';
          btn.classList.remove('active');
        }
      });

      window.addEventListener('resize', function() {
        if (!isMobile()) {
          menu.style.display = '';
          btn.classList.remove('active');
        } else if (menu.style.display === '' || menu.style.display === 'flex') {
          menu.style.display = 'none';
        }
      });
    })();
  </script>

  <main class="main-content">