<%- include('partials/header') %>

<div class="card" style="max-width: 700px; margin: 0 auto;">
  <h2 style="text-align: center; margin-bottom: 25px;">写一篇新游记</h2>

  <% if (typeof error !== 'undefined') { %>
    <div style="background: #ffeaa7; padding: 10px; border-radius: 5px; margin-bottom: 15px; color: #d63031;">
      <%= error %>
    </div>
  <% } %>

  <form action="/create" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label for="title">游记标题</label>
      <input type="text" name="title" id="title" required placeholder="给你的游记起个名字">
    </div>

    <div class="form-group">
      <label for="destination">目的地</label>
      <input type="text" name="destination" id="destination" required placeholder="比如：云南大理、日本东京">
    </div>

    <div class="form-group">
      <label for="category">旅行类型</label>
      <select name="category" id="category">
        <option value="自然风光">自然风光</option>
        <option value="城市漫步">城市漫步</option>
        <option value="美食之旅">美食之旅</option>
        <option value="历史文化">历史文化</option>
        <option value="其他">其他</option>
      </select>
    </div>

    <div class="form-group">
      <label for="image">封面图片（可选）</label>
      <input type="file" name="image" id="image" accept="image/*">
    </div>

    <div class="form-group">
      <label for="gallery">更多图片（可选，可多选）</label>
      <input type="file" name="gallery" id="gallery" accept="image/*" multiple>
    </div>

    <div class="form-group">
      <label for="content">游记正文</label>
      <textarea name="content" id="content" rows="12" required placeholder="分享你的旅行故事..."></textarea>
    </div>

    <button type="submit" class="btn btn-primary" style="width: 100%;">发布游记</button>
  </form>
</div>

<%- include('partials/footer') %>