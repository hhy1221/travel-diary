<%- include('partials/header') %>

<style>
  .admin-container { max-width: 900px; margin: 0 auto; padding: 20px 0 60px; }
  .admin-title { color: var(--primary); margin-bottom: 8px; font-size: 1.8rem; }
  .admin-subtitle { color: var(--light); margin-bottom: 30px; }
  .admin-section { background: var(--card-bg); border: var(--card-border); border-radius: var(--radius); padding: 28px; margin-bottom: 24px; }
  .admin-section h3 { margin-bottom: 18px; color: var(--text); font-size: 1.2rem; }
  .mode-toggle { display: flex; gap: 0; margin-bottom: 20px; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); }
  .mode-btn { flex: 1; padding: 12px 20px; text-align: center; cursor: pointer; background: #f8f8f8; border: none; font-size: 0.95rem; transition: all 0.2s; }
  .mode-btn.active { background: var(--primary); color: #fff; font-weight: 600; }
  .image-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; margin-bottom: 20px; }
  .image-card { position: relative; border-radius: var(--radius); overflow: hidden; border: 3px solid transparent; cursor: pointer; transition: all 0.2s; aspect-ratio: 16/9; }
  .image-card.selected { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(233,69,96,0.2); }
  .image-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .image-card .check-mark { position: absolute; top: 8px; right: 8px; width: 24px; height: 24px; border-radius: 50%; background: var(--primary); color: #fff; display: none; align-items: center; justify-content: center; font-size: 14px; }
  .image-card.selected .check-mark { display: flex; }
  .delete-btn { position: absolute; bottom: 6px; right: 6px; width: 26px; height: 26px; border-radius: 50%; background: rgba(0,0,0,0.55); color: #fff; border: none; cursor: pointer; font-size: 14px; line-height: 1; display: flex; align-items: center; justify-content: center; transition: background 0.2s; z-index: 2; }
  .delete-btn:hover { background: #e74c3c; }
  .image-card.static-radio .delete-btn { bottom: 6px; right: 6px; }
  .image-card.static-radio { display: flex; align-items: center; justify-content: center; }
  .image-card .radio-dot { width: 20px; height: 20px; border-radius: 50%; border: 2px solid #ccc; position: absolute; top: 8px; left: 8px; background: #fff; }
  .image-card.static-selected .radio-dot { border-color: var(--primary); background: var(--primary); }
  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; margin-bottom: 6px; font-weight: 600; color: var(--text); }
  .form-group input, .form-group select { width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.95rem; }
  .form-group input[type="range"] { padding: 0; }
  .btn-save { padding: 12px 32px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 1rem; cursor: pointer; font-weight: 600; }
  .btn-save:hover { opacity: 0.9; }
  .upload-area { border: 2px dashed var(--border); border-radius: var(--radius); padding: 30px; text-align: center; margin-bottom: 14px; }
  .upload-area input[type="file"] { margin-top: 12px; }
  .toast { position: fixed; top: 24px; right: 24px; background: #4caf50; color: #fff; padding: 14px 24px; border-radius: var(--radius); z-index: 9999; animation: fadeInUp 0.3s ease; }
  .toast.error { background: #e74c3c; }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .static-select-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
</style>

<div class="admin-container">
  <h1 class="admin-title">管理员后台</h1>
  <p class="admin-subtitle">配置首页 Hero 区域的背景图展示方式</p>

  <% if (typeof query !== 'undefined' && query.saved) { %>
    <div class="toast" id="toast">设置已保存！</div>
  <% } %>
  <% if (typeof query !== 'undefined' && query.uploaded) { %>
    <div class="toast" id="toast">图片上传成功，已自动加入轮播列表！</div>
  <% } %>
  <% if (typeof query !== 'undefined' && query.deleted) { %>
    <div class="toast" id="toast">图片已删除！</div>
  <% } %>
  <% if (typeof query !== 'undefined' && query.delete_error) { %>
    <div class="toast error" id="toast">删除失败，请重试</div>
  <% } %>

  <form method="POST" action="/admin/settings">
    <div class="admin-section">
      <h3>展示模式</h3>
      <div class="mode-toggle" id="modeToggle">
        <button type="button" class="mode-btn <%= setting.heroMode !== 'static' ? 'active' : '' %>" data-mode="carousel">轮播模式</button>
        <button type="button" class="mode-btn <%= setting.heroMode === 'static' ? 'active' : '' %>" data-mode="static">静止模式</button>
      </div>
      <input type="hidden" name="heroMode" id="heroModeInput" value="<%= setting.heroMode || 'carousel' %>">

      <div id="carouselSettings" style="<%= setting.heroMode === 'static' ? 'display:none' : '' %>">
        <h3 style="margin-top:16px;">选择轮播图片（多选）</h3>
        <div class="image-grid">
          <% var selectedImages = setting.heroImages || []; %>
          <% allImages.forEach(function(img) { %>
            <% var isSel = selectedImages.indexOf(img) !== -1; %>
            <div class="image-card <%= isSel ? 'selected' : '' %>" data-image="<%= img %>" onclick="toggleImage(this)">
              <img src="/images/<%= img %>" alt="<%= img %>">
              <div class="check-mark">✓</div>
              <button type="button" class="delete-btn" title="删除此图片" onclick="event.stopPropagation(); deleteImage('<%= img %>')">✕</button>
              <input type="checkbox" name="heroImages" value="<%= img %>" <%= isSel ? 'checked' : '' %> style="display:none;">
            </div>
          <% }); %>
        </div>
        <div class="form-group">
          <label>切换间隔（秒）</label>
          <input type="range" name="heroInterval" min="2" max="15" value="<%= Math.round((setting.heroInterval || 5000) / 1000) %>" oninput="this.nextElementSibling.value = this.value + ' 秒'">
          <output><%= Math.round((setting.heroInterval || 5000) / 1000) %> 秒</output>
        </div>
      </div>

      <div id="staticSettings" style="<%= setting.heroMode === 'static' ? '' : 'display:none' %>">
        <h3 style="margin-top:16px;">选择静止图片（单选）</h3>
        <div class="static-select-grid">
          <% var staImg = setting.heroStaticImage || ''; %>
          <% allImages.forEach(function(img) { %>
            <div class="image-card static-radio <%= staImg === img ? 'static-selected' : '' %>" data-image="<%= img %>" onclick="selectStatic(this)">
              <img src="/images/<%= img %>" alt="<%= img %>">
              <div class="radio-dot"></div>
              <button type="button" class="delete-btn" title="删除此图片" onclick="event.stopPropagation(); deleteImage('<%= img %>')">✕</button>
              <input type="radio" name="heroStaticImage" value="<%= img %>" <%= staImg === img ? 'checked' : '' %> style="display:none;">
            </div>
          <% }); %>
        </div>
      </div>
    </div>

    <button type="submit" class="btn-save">保存设置</button>
  </form>

  <div class="admin-section" style="margin-top:24px;">
    <h3>上传新图片</h3>
    <form method="POST" action="/admin/upload" enctype="multipart/form-data">
      <div class="upload-area">
        <p style="color:var(--light); margin-bottom:12px;">选择任意图片上传，上传后将自动命名为 hero-xxx 并加入轮播列表</p>
        <input type="file" name="cover" accept="image/*" required>
      </div>
      <button type="submit" class="btn-save">上传</button>
    </form>
  </div>
</div>

<script>
  setTimeout(function() { var t = document.getElementById('toast'); if (t) t.style.display = 'none'; }, 3000);

  document.querySelectorAll('.mode-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.mode-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var mode = btn.dataset.mode;
      document.getElementById('heroModeInput').value = mode;
      document.getElementById('carouselSettings').style.display = mode === 'static' ? 'none' : '';
      document.getElementById('staticSettings').style.display = mode === 'static' ? '' : 'none';
    });
  });

  function toggleImage(el) {
    el.classList.toggle('selected');
    var cb = el.querySelector('input[type="checkbox"]');
    cb.checked = !cb.checked;
  }

  function selectStatic(el) {
    document.querySelectorAll('.static-radio').forEach(function(r) { r.classList.remove('static-selected'); });
    el.classList.add('static-selected');
    var rb = el.querySelector('input[type="radio"]');
    rb.checked = true;
  }

  function deleteImage(filename) {
    if (!confirm('确定要删除 ' + filename + ' 吗？此操作不可撤销。')) return;
    var form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/delete-image';
    var input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'filename';
    input.value = filename;
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
  }
</script>

<%- include('partials/footer') %>
