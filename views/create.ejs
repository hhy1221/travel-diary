<%- include('partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

<div class="card" style="max-width:800px; margin:0 auto;">
  <h2 style="margin-bottom:25px; color:var(--primary);">撰写新游记</h2>
  <% if (typeof error !== 'undefined' && error) { %>
    <div style="background:#ffeaa7; padding:10px; border-radius:8px; margin-bottom:15px; color:#d63031;"><%= error %></div>
  <% } %>
  <form action="/create" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label>游记标题</label>
      <input type="text" name="title" required placeholder="给你的游记起个名字">
    </div>
    <div class="form-group">
      <label>目的地</label>
      <input type="text" name="destination" required placeholder="比如：云南大理、日本东京">
    </div>
    <div class="form-group">
      <label>旅行类型</label>
      <select name="category">
        <option>自然风光</option><option>城市漫步</option><option>美食之旅</option><option>历史文化</option><option>其他</option>
      </select>
    </div>
    <div class="form-group">
      <label>封面图片</label>
      <input type="file" name="image" accept="image/*">
    </div>
    <div class="form-group">
      <label>更多图片（可多选）</label>
      <input type="file" name="gallery" accept="image/*" multiple>
    </div>
    <div class="form-group">
      <label>游记正文</label>
      <!-- 隐藏的原始 textarea，用于提交表单 -->
      <input type="hidden" name="content" id="content-input">
      <!-- Quill 编辑器容器 -->
      <div id="editor-container" style="height: 400px; background: rgba(255,255,255,0.9); border-radius: 10px;"></div>
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;">发布游记</button>
  </form>
  <script>
  // 初始化 Quill 编辑器
  var quill = new Quill('#editor-container', {
    theme: 'snow',
    placeholder: '分享你的旅行故事...',
    modules: {
      toolbar: [
        ['bold', 'italic', 'underline'],
        [{ 'header': [1, 2, false] }],
        ['link', 'image'],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        ['clean']
      ]
    }
  });

  // 提交表单前，把编辑器内容写入隐藏的 input
  var form = document.querySelector('form');
  form.onsubmit = function() {
    var contentInput = document.getElementById('content-input');
    contentInput.value = quill.root.innerHTML;
  };
</script>
</div>

<%- include('partials/footer') %>